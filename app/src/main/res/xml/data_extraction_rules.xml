<?xml version="1.0" encoding="utf-8"?><!--
   Backup/transfer rules for API 31+ (android:dataExtractionRules).
   Only saved shaft documents are backed up/transferred: they are the
   irreplaceable user data. Settings, autosave drafts, and internal snapshots
   are excluded (specifying any <include> limits backup to exactly those paths).
-->
<data-extraction-rules>
    <cloud-backup>
        <include domain="file" path="shafts/" />
    </cloud-backup>
    <device-transfer>
        <include domain="file" path="shafts/" />
    </device-transfer>
</data-extraction-rules>
