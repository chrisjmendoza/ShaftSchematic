<?xml version="1.0" encoding="utf-8"?><!--
   Auto Backup rules for devices below API 31 (android:fullBackupContent).
   Only saved shaft documents are backed up: they are the irreplaceable user
   data. Settings, autosave drafts, and internal snapshots are excluded
   (specifying any <include> limits backup to exactly those paths).
-->
<full-backup-content>
    <include domain="file" path="shafts/" />
</full-backup-content>
